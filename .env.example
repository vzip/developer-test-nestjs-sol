# ─────────────────────────────────────────────────────────────
# Select network: ethereum | bnb | polygon | solana | ton
# ─────────────────────────────────────────────────────────────
NETWORK=ethereum

# ─────────────────────────────────────────────────────────────
# RPC URLs (replace with your own or use the free public defaults)
# ─────────────────────────────────────────────────────────────

# Ethereum — free public RPC
ETH_RPC_URL=https://eth.llamarpc.com

# BNB Chain — free public RPC
BNB_RPC_URL=https://bsc-dataseed.binance.org

# Polygon — free public RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Solana — public mainnet RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TON — public RPC (free tier, no key needed for basic usage)
# Rate-limited: for production use https://toncenter.com to get an API key
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=

# ─────────────────────────────────────────────────────────────
# API keys for EVM transaction history (free registration)
# Etherscan:   https://etherscan.io/apis
# BscScan:     https://bscscan.com/apis
# Polygonscan: https://polygonscan.com/apis
# ─────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# ─────────────────────────────────────────────────────────────
# Moralis — unified multi-chain API for tokens & NFTs
# Free API key: https://admin.moralis.io
# Used by: GET /wallet/:address/tokens  and  GET /wallet/:address/nfts
# ─────────────────────────────────────────────────────────────
MORALIS_API_KEY=

# ─────────────────────────────────────────────────────────────
# Redis (start with: docker-compose up -d)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
PORT=3000
